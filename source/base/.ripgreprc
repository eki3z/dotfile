--no-messages
--hidden
--follow
--trim
--smart-case
--auto-hybrid-regex
--sortr=modified
--ignore-file=~/.config/rg/.rgignore

# ui
--colors=path:fg:blue
--colors=path:style:underline

--colors=match:fg:green
--colors=match:style:bold

--colors=line:fg:yellow
--colors=line:style:bold

--colors=column:fg:yellow
--colors=line:style:bold
